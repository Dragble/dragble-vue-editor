{
  "name": "dragble-vue-editor",
  "version": "1.0.0",
  "description": "Vue 3 email editor component AI powered drag-and-drop email builder for creating responsive email templates and newsletters. Build HTML emails visually with Dragble.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rollup -c",
    "build:watch": "rollup -c -w",
    "dev": "rollup -c -w",
    "test": "vitest",
    "lint": "eslint src --ext .ts,.vue",
    "typecheck": "vue-tsc --noEmit",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run build",
    "prepare": "husky"
  },
  "keywords": [
    "dragble",
    "email",
    "email-editor",
    "email-builder",
    "email-template",
    "email-template-builder",
    "email-template-editor",
    "email-designer",
    "email-design",
    "html-email",
    "html-email-editor",
    "html-email-builder",
    "responsive-email",
    "newsletter",
    "newsletter-builder",
    "newsletter-editor",
    "newsletter-template",
    "vue",
    "vue3",
    "vue-email",
    "vue-email-editor",
    "vue-email-builder",
    "vue-component",
    "editor",
    "template-editor",
    "template-builder",
    "drag-and-drop",
    "drag-drop-editor",
    "visual-editor",
    "wysiwyg",
    "wysiwyg-editor",
    "page-builder",
    "web-page-builder",
    "landing-page-builder",
    "no-code",
    "low-code",
    "design-tool",
    "email-marketing",
    "email-campaign",
    "transactional-email",
    "mailchimp",
    "sendgrid",
    "mjml",
    "embed",
    "embeddable",
    "sdk",
    "content-builder",
    "email-automation"
  ],
  "author": "Dragble",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Dragble/dragble-vue-editor.git"
  },
  "bugs": {
    "url": "https://github.com/Dragble/dragble-vue-editor/issues"
  },
  "homepage": "https://docs.dragble.com",
  "dependencies": {
    "dragble-types": "latest"
  },
  "peerDependencies": {
    "vue": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": false
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-typescript": "^11.1.5",
    "@types/node": "^20.10.4",
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "@typescript-eslint/parser": "^6.13.2",
    "eslint": "^8.55.0",
    "husky": "^9.1.7",
    "rollup": "^4.9.0",
    "rollup-plugin-dts": "^6.1.0",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "tslib": "^2.8.1",
    "typescript": "^5.3.3",
    "vitest": "^1.0.4",
    "vue": "^3.3.11",
    "vue-tsc": "^2.0.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
